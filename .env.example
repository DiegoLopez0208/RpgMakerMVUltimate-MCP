# Required: Path to your RPG Maker MV project
RPGMAKER_PROJECT_PATH=/path/to/your/rpg-maker-mv-project

# Optional: Vision AI configuration (for analyze_screenshot tool)
# Works with any OpenAI-compatible vision endpoint (LocalAI, Ollama, NVIDIA, OpenAI, etc.)
VISION_API_URL=http://127.0.0.1:9999
VISION_API_KEY=sk-proxy
VISION_MODEL=meta/llama-3.2-90b-vision-instruct
VISION_API_PATH=/v1/chat/completions
